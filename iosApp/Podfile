platform :ios, '15.0'
use_frameworks! :linkage => :static

# Workspace: iosApp.xcworkspace

target 'iosApp' do
  # KMP top-level module — exports Core internally via export(project(":core"))
  # DO NOT add 'Core' pod separately — it would cause 66 duplicate Compose runtime symbols
  pod 'AppMan', :path => '../app'

  # Firebase — required by AppMan/Core (dev.gitlive firebase-storage, firebase-app)
  pod 'FirebaseCore'
  pod 'FirebaseStorage'
  pod 'FirebaseAnalytics'
  pod 'FirebaseCrashlytics'

  # Required by mediaplayer-kmp (iOS player component)
  pod 'YouTubePlayerKit'
end

post_install do |installer|
  # Read TMDB_ACCESS_TOKEN from Secrets.xcconfig
  secrets_path = File.join(File.dirname(__FILE__), 'Configuration/Secrets.xcconfig')
  tmdb_token = ''
  if File.exist?(secrets_path)
    File.readlines(secrets_path).each do |line|
      match = line.strip.match(/^TMDB_ACCESS_TOKEN\s*=\s*(.+)$/)
      tmdb_token = match[1].strip if match
    end
  end
  puts "[Podfile] TMDB_ACCESS_TOKEN found: #{!tmdb_token.empty?}"

  # Inject TMDB_ACCESS_TOKEN into the aggregate target xcconfig files
  # (The Pods-iosApp.debug/release.xcconfig is the baseConfigurationReference — it does
  #  NOT include Config.xcconfig, so the token must be injected directly here)
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.xcconfigs.each do |config_name, config_file|
      unless tmdb_token.empty?
        config_file.attributes['TMDB_ACCESS_TOKEN'] = tmdb_token
      end
      xcconfig_path = aggregate_target.xcconfig_path(config_name)
      config_file.save_as(Pathname.new(xcconfig_path))
    end
  end

  # Resolve JAVA_HOME dynamically: prefer asdf-managed Java, fallback to /usr/libexec/java_home
  java_home = `~/.asdf/shims/java -XshowSettings:property -version 2>&1 | grep 'java.home' | awk '{print $3}'`.strip
  if java_home.empty?
    java_home = `/usr/libexec/java_home 2>/dev/null`.strip
  end
  if java_home.empty? || java_home == "null"
    asdf_java_dir = File.expand_path("~/.asdf/installs/java")
    if Dir.exist?(asdf_java_dir)
      candidates = Dir.glob("#{asdf_java_dir}/*/bin/java").sort.last
      java_home = File.dirname(File.dirname(candidates)) if candidates
    end
  end

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end

    # Inject JAVA_HOME into the KMP syncFramework script phases
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:shell_script)
      next unless phase.shell_script.include?('syncFramework')
      unless java_home.empty?
        phase.shell_script = "export JAVA_HOME=\"#{java_home}\"\nexport PATH=\"#{java_home}/bin:$PATH\"\n" + phase.shell_script
      end
    end
  end
end
